		value '60Hz'
		comment {
			access 'read write'
			type ENUMERATED
			count 1
			item.0 '3.79Hz'
			item.1 '60Hz'
			item.2 '243Hz'
			item.3 '493Hz'
		}
	}
	control.6 {
		iface MIXER
		name 'HPFL Switch'
		value true
		comment {
			access 'read write'
			type BOOLEAN
			count 1
		}
	}
	control.7 {
		iface MIXER
		name 'HPFR Switch'
		value true
		comment {
			access 'read write'
			type BOOLEAN
			count 1
		}
	}
	control.8 {
		iface PCM
		name 'PDM Start Delay Ms'
		value 20
		comment {
			access 'read write'
			type INTEGER
			count 1
			range '0 - 1000 (step 1)'
		}
	}
	control.9 {
		iface PCM
		name 'PDM Filter Delay Ms'
		value 20
		comment {
			access 'read write'
			type INTEGER
			count 1
			range '20 - 1000 (step 1)'
		}
	}
	control.10 {
		iface MIXER
		name MicGain
		value.0 70
		value.1 70
		comment {
			access 'read write user'
			type INTEGER
			count 2
			range '0 - 99'
			tlv '0000000100000008fffffc1800000028'
			dbmin -1000
			dbmax 2960
			dbvalue.0 1800
			dbvalue.1 1800
		}
	}
}